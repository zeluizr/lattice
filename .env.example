# Credential for the lattice in-dashboard chat.
# Copy this file to `.env` (in the directory you run lattice from, or to
# ~/.config/lattice/.env) and fill it in. The chat is optional — every other
# panel works without any credential.

# >>> RECOMMENDED <<<
# Console API key (https://console.anthropic.com → Settings → API Keys).
# Billed per token; with Haiku 4.5 each question costs a fraction of a cent.
ANTHROPIC_API_KEY=sk-ant-api03-...

# ----------------------------------------------------------------------------
# Subscription token from `claude setup-token` (sk-ant-oat01-...): lattice
# accepts it (sent as a Bearer token with the OAuth beta header), but note the
# Messages API may reject OAuth tokens depending on your account. If so, use the
# console API key above.
# ANTHROPIC_API_KEY=sk-ant-oat01-...
